# Public (exposed to the browser via Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase (never expose to the browser)
# SUPABASE_URL is optional; when empty, server/demo code falls back to NEXT_PUBLIC_SUPABASE_URL
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only OpenAI key for DailyBuddy (Vercel AI SDK / @ai-sdk/openai)
OPENAI_API_KEY=
